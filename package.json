{
  "name": "estoque-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "env:supabase-ref": "node scripts/show-supabase-project-ref.mjs",
    "sync:mcp-supabase": "node scripts/sync-cursor-mcp-supabase.mjs",
    "dev": "next dev -H ::",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint",
    "ci": "npm ci && npm run build",
    "railway:deploy": "railway up --detach",
    "railway:wait": "node scripts/railway-wait-deployment.mjs",
    "railway:release": "railway up --detach && node scripts/railway-wait-deployment.mjs",
    "railway:diagnose": "node scripts/railway-diagnose.mjs",
    "seed:operacional": "node scripts/seed-credenciais-operacionais.mjs",
    "railway:prune-queued": "node scripts/railway-prune-queued.mjs",
    "test:historico-producao": "node scripts/test-historico-producao.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.91.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.562.0",
    "next": "16.1.4",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "pg": "^8.18.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
