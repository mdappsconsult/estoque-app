# Copiar para `.env` no Raspberry (`~/pi-print-ws/.env`). Não commitar segredos.

PRINT_WS_TOKEN=
CUPS_QUEUE=ZebraZD220

# Fallback de tamanho de folha (viewport Chromium) quando o JSON **não** traz widthMm/heightMm.
# Padrão no código: 60×60 mm (etiqueta quadrada). Pi usado **só** para separação 60×30 pode forçar:
# PRINT_DEFAULT_WIDTH_MM=60
# PRINT_DEFAULT_HEIGHT_MM=30

PRINT_WS_PORT=8765
